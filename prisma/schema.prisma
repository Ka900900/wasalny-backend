generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageType {
  TEXT
  LOCATION
  IMAGE
}

enum VehicleType {
  PRIVATE_CAR
  TAXI
  SCOOTER
  MOTORCYCLE
}

enum ServiceTier {
  ECO
  COMFORT
  PREMIUM
}

enum WalletTransactionType {
  RIDE_HOLD
  RIDE_DEDUCTION
  RIDE_REFUND
  DRIVER_EARNING
  COMMISSION
  TOPUP
  WITHDRAWAL
}

enum WalletTransactionStatus {
  HELD
  SETTLED
  RELEASED
  COMPLETED
}

enum WithdrawStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

enum SenderType {
  USER
  ADMIN
  SYSTEM
}

model User {
  id           String   @id @default(cuid())
  firebaseUid  String?  @unique
  phoneNumber  String?  @unique
  email        String?
  firstName    String
  lastName     String
  role         String   @default("RIDER")
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  otpCode      String?
  otpExpiresAt DateTime?
  avatarUrl    String?
  fcmToken     String?   @map("fcm_token") // Firebase Cloud Messaging token for push notifications
  notificationPreferences Boolean? @default(true) @map("notification_preferences") // استقبال العروض والإشعارات
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ridesAsRider    RideRequest[] @relation("RiderRides")
  ridesAsDriver   RideRequest[] @relation("DriverRides")
  driverProfile   DriverProfile?
  ratingsGiven    Rating[] @relation("RatingsGiven")
  ratingsReceived Rating[] @relation("RatingsReceived")
  wallet          Wallet?
  supportMessages  SupportMessage[]
  supportTickets   SupportTicket[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  rideMessages     RideMessage[] @relation("RideMessageSender")
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model SupportTicket {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rideId    String?
  ride      RideRequest? @relation(fields: [rideId], references: [id], onDelete: SetNull)
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  messages SupportMessage[]

  @@index([userId])
  @@index([status])
}

model SupportMessage {
  id         String     @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderType SenderType @default(USER)
  text       String
  createdAt  DateTime   @default(now())

  @@index([ticketId])
}

model DriverProfile {
  id             String          @id @default(cuid())
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  carModel       String
  carPlateNumber String
  carColor       String
  vehicleType    VehicleType
  serviceTier    ServiceTier?
  carPhotoUrl    String

  // ── Identity verification documents ──
  idPhotoFront   String?         // البطاقة الشخصية – وجه
  idPhotoBack    String?         // البطاقة الشخصية – ظهر
  licensePhoto   String?         // رخصة القيادة
  facePhoto      String?         // صورة شخصية (selfie) للتحقق من الهوية
  insurancePhoto String?         // وثيقة التأمين

  // ── صور إضافية للبطاقة والرخصة (الوجه الآخر + Cloudinary Public IDs) ──
  idCardBackUrl        String?   // رابط صورة ظهر البطاقة الشخصية
  licenseBackUrl       String?   // رابط صورة ظهر رخصة القيادة
  idCardBackPublicId   String?   // Cloudinary Public ID لصورة ظهر البطاقة
  licenseBackPublicId  String?   // Cloudinary Public ID لصورة ظهر الرخصة

  isAvailable    Boolean         @default(true)
  currentLat     Float?
  currentLng     Float?
  balance        Decimal         @db.Decimal(10, 2) @default(0)
  totalTrips     Int             @default(0)
  totalEarnings  Decimal         @db.Decimal(10, 2) @default(0)
  ratingAvg      Float           @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model RideOption {
  id              String          @id @default(cuid())
  name            String
  nameAr          String
  description     String
  descriptionAr   String
  icon            String
  capacity        Int             @default(4)
  serviceTier     ServiceTier?
  baseFare        Decimal         @db.Decimal(10, 2) @default(10)
  pricePerKm      Decimal         @db.Decimal(10, 2) @default(4)
  pricePerMinute  Decimal         @db.Decimal(10, 2) @default(0.75)
  multiplier       Decimal         @db.Decimal(10, 2) @default(1.0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now())

  rides RideRequest[]
}

model RideRequest {
  id           String          @id @default(cuid())
  riderId      String
  rider        User            @relation("RiderRides", fields: [riderId], references: [id], onDelete: Cascade)

  rideOptionId String?
  rideOption   RideOption?     @relation(fields: [rideOptionId], references: [id])
  rideType     String?

  serviceTier            ServiceTier?          @default(ECO)
  estimatedFare         Decimal?              @db.Decimal(10, 2)
  finalPricePerKm       Decimal?              @db.Decimal(10, 2)
  surgeMultiplierApplied Decimal?              @db.Decimal(10, 2)
  holdPlaced            Boolean               @default(false)

  pickupPoint        String
  pickupAddress      String  @default("")
  dropoffPoint       String
  destinationAddress String @default("")
  originLat          Float
  originLng          Float
  destLat            Float
  destLng            Float

  price           Decimal  @db.Decimal(10, 2)
  distance        Float
  durationMinutes Int     @default(0)
  pricePerKm      Decimal  @db.Decimal(10, 2) @default(7)
  commission      Decimal  @db.Decimal(10, 2) @default(0)
  commissionRate  Decimal  @db.Decimal(5, 4) @default(0)
  driverEarning   Decimal  @db.Decimal(10, 2) @default(0)

  status       String  @default("PENDING")
  isPaid       Boolean @default(false)
  paidAt       DateTime?
  paymentMethod String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driverId String?
  driver   User?   @relation("DriverRides", fields: [driverId], references: [id], onDelete: SetNull)

  ratings Rating[]

  walletTransactions WalletTransaction[]
  messages          Message[]
  rideMessages      RideMessage[]
  supportTickets    SupportTicket[]

  driverCurrentLat Float?
  driverCurrentLng Float?
  driverEtaMinutes Int?
}

model Rating {
  id         String   @id @default(cuid())
  rideId     String
  ride       RideRequest @relation(fields: [rideId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser   User     @relation("RatingsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User     @relation("RatingsReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([rideId, fromUserId])
  @@index([toUserId])
}

model Wallet {
  id              String          @id @default(cuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance         Decimal         @db.Decimal(10, 2) @default(0)
  reservedAmount  Decimal         @db.Decimal(10, 2) @default(0)
  pendingWithdraw Decimal         @db.Decimal(10, 2) @default(0)
  totalEarned     Decimal         @db.Decimal(10, 2) @default(0)
  totalWithdrawn  Decimal         @db.Decimal(10, 2) @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now())

  transactions   WalletTransaction[]
  withdraws      WithdrawRequest[]
  paymentMethods PaymentMethod[]
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  wallet      Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        WalletTransactionType
  amount      Decimal               @db.Decimal(10, 2)
  balanceAfter Decimal              @db.Decimal(10, 2)
  status      WalletTransactionStatus @default(COMPLETED)
  description String
  metadata    Json?
  rideId      String?
  ride        RideRequest?         @relation(fields: [rideId], references: [id], onDelete: Restrict)
  createdAt   DateTime              @default(now())
}

model WithdrawRequest {
  id             String         @id @default(cuid())
  walletId       String
  wallet         Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount         Decimal        @db.Decimal(10, 2)
  status         WithdrawStatus @default(PENDING)
  bankName       String?
  bankAccount    String?
  accountHolder  String?
  rejectReason   String?
  paidAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model PaymentMethod {
  id            String   @id @default(cuid())
  walletId      String
  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          String
  brand         String?
  lastFour      String?
  cardholderName String?
  expiryDate    String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model PaymentSession {
  id               String    @id @default(cuid())
  orderId          String    @unique
  sessionId        String
  paymentMethod    String?
  amount           Decimal?  @db.Decimal(10, 2)
  status           String    @default("CREATED")
  paymentReference String?   // مرجع الدفع من Kashier بعد التأكيد
  confirmedAt      DateTime? // توقيت تأكيد الدفع
  failureReason    String?   // سبب فشل الدفع إن حدث
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Config {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  valueType   String   @default("NUMBER")
  description String?
  updatedAt   DateTime @updatedAt
}

model Vehicle {
  id              String      @id @default(cuid())
  userId          String
  make            String
  model           String
  year            Int
  color           String
  plateNumber     String      @unique
  vehicleType     VehicleType
  licenseFrontUrl String
  licenseBackUrl  String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Message {
  id         String      @id @default(uuid())
  tripId     String
  senderId   String
  receiverId String
  content    String
  type       MessageType @default(TEXT)
  isRead     Boolean     @default(false)
  createdAt  DateTime    @default(now())

  trip       RideRequest @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sender     User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User        @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model RideMessage {
  id        String   @id @default(cuid())
  rideId    String
  senderId  String
  senderType String
  text      String
  createdAt DateTime @default(now())

  ride   RideRequest @relation(fields: [rideId], references: [id], onDelete: Cascade)
  sender User       @relation("RideMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([rideId])
}
