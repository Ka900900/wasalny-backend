generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleType {
  PRIVATE_CAR
  TAXI
  SCOOTER
}

enum ServiceTier {
  ECO
  COMFORT
  PREMIUM
}

enum WalletTransactionType {
  RIDE_HOLD
  RIDE_DEDUCTION
  RIDE_REFUND
  DRIVER_EARNING
  COMMISSION
  TOPUP
  WITHDRAWAL
}

enum WalletTransactionStatus {
  HELD
  SETTLED
  RELEASED
  COMPLETED
}

enum WithdrawStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  firebaseUid  String?  @unique
  phoneNumber  String?  @unique
  email        String?
  firstName    String
  lastName     String
  role         String   @default("RIDER")
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  otpCode      String?
  otpExpiresAt DateTime?
  avatarUrl    String?
  fcmToken     String?  @map("fcm_token") // Firebase Cloud Messaging token for push notifications
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ridesAsRider    RideRequest[] @relation("RiderRides")
  ridesAsDriver   RideRequest[] @relation("DriverRides")
  driverProfile   DriverProfile?
  ratingsGiven    Rating[] @relation("RatingsGiven")
  ratingsReceived Rating[] @relation("RatingsReceived")
  wallet          Wallet?
  supportMessages SupportMessage[]
}

model SupportMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  sender    String
  text      String
  createdAt DateTime @default(now())
}

model DriverProfile {
  id             String          @id @default(cuid())
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  carModel       String
  carPlateNumber String
  carColor       String
  vehicleType    VehicleType
  serviceTier    ServiceTier?
  carPhotoUrl    String
  isAvailable    Boolean         @default(true)
  currentLat     Float?
  currentLng     Float?
  balance        Decimal         @db.Decimal(10, 2) @default(0)
  totalTrips     Int             @default(0)
  totalEarnings  Decimal         @db.Decimal(10, 2) @default(0)
  ratingAvg      Float           @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model RideOption {
  id              String          @id @default(cuid())
  name            String
  nameAr          String
  description     String
  descriptionAr   String
  icon            String
  capacity        Int             @default(4)
  serviceTier     ServiceTier?
  baseFare        Decimal         @db.Decimal(10, 2) @default(10)
  pricePerKm      Decimal         @db.Decimal(10, 2) @default(4)
  pricePerMinute  Decimal         @db.Decimal(10, 2) @default(0.75)
  multiplier       Decimal         @db.Decimal(10, 2) @default(1.0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now())

  rides RideRequest[]
}

model RideRequest {
  id           String          @id @default(cuid())
  riderId      String
  rider        User            @relation("RiderRides", fields: [riderId], references: [id])

  rideOptionId String?
  rideOption   RideOption?     @relation(fields: [rideOptionId], references: [id])
  rideType     String?

  serviceTier            ServiceTier?          @default(ECO)
  estimatedFare         Decimal?              @db.Decimal(10, 2)
  finalPricePerKm       Decimal?              @db.Decimal(10, 2)
  surgeMultiplierApplied Decimal?              @db.Decimal(10, 2)
  holdPlaced            Boolean               @default(false)

  pickupPoint        String
  pickupAddress      String  @default("")
  dropoffPoint       String
  destinationAddress String @default("")
  originLat          Float
  originLng          Float
  destLat            Float
  destLng            Float

  price           Decimal  @db.Decimal(10, 2)
  distance        Float
  durationMinutes Int     @default(0)
  pricePerKm      Decimal  @db.Decimal(10, 2) @default(7)
  commission      Decimal  @db.Decimal(10, 2) @default(0)
  commissionRate  Decimal  @db.Decimal(5, 4) @default(0)
  driverEarning   Decimal  @db.Decimal(10, 2) @default(0)

  status       String  @default("PENDING")
  isPaid       Boolean @default(false)
  paidAt       DateTime?
  paymentMethod String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driverId String?
  driver   User?   @relation("DriverRides", fields: [driverId], references: [id], onDelete: Restrict)

  rating Rating?

  walletTransactions WalletTransaction[]

  driverCurrentLat Float?
  driverCurrentLng Float?
  driverEtaMinutes Int?
}

model Rating {
  id         String   @id @default(cuid())
  rideId     String   @unique
  ride       RideRequest @relation(fields: [rideId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser   User     @relation("RatingsGiven", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation("RatingsReceived", fields: [toUserId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}

model Wallet {
  id              String          @id @default(cuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance         Decimal         @db.Decimal(10, 2) @default(0)
  reservedAmount  Decimal         @db.Decimal(10, 2) @default(0)
  pendingWithdraw Decimal         @db.Decimal(10, 2) @default(0)
  totalEarned     Decimal         @db.Decimal(10, 2) @default(0)
  totalWithdrawn  Decimal         @db.Decimal(10, 2) @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now())

  transactions   WalletTransaction[]
  withdraws      WithdrawRequest[]
  paymentMethods PaymentMethod[]
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  wallet      Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        WalletTransactionType
  amount      Decimal               @db.Decimal(10, 2)
  balanceAfter Decimal              @db.Decimal(10, 2)
  status      WalletTransactionStatus @default(COMPLETED)
  description String
  metadata    Json?
  rideId      String?
  ride        RideRequest?         @relation(fields: [rideId], references: [id], onDelete: Restrict)
  createdAt   DateTime              @default(now())
}

model WithdrawRequest {
  id             String         @id @default(cuid())
  walletId       String
  wallet         Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount         Decimal        @db.Decimal(10, 2)
  status         WithdrawStatus @default(PENDING)
  bankName       String?
  bankAccount    String?
  accountHolder  String?
  rejectReason   String?
  paidAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model PaymentMethod {
  id            String   @id @default(cuid())
  walletId      String
  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          String
  brand         String?
  lastFour      String?
  cardholderName String?
  expiryDate    String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Config {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  valueType   String   @default("NUMBER")
  description String?
  updatedAt   DateTime @updatedAt
}
