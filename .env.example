# ══════════════════════════════════════════════════════════════════════════
#  Waslny Backend — نموذج متغيرات البيئة (قالب / Template)
#  انسخ هذا الملف إلى  .env  واملأ القيم الحقيقية.
#  ⚠️ لا ترفع ملف  .env  (الذي يحتوي الأسرار) إلى Git — تم استثناؤه في .gitignore.
# ══════════════════════════════════════════════════════════════════════════

# ── الخادم (Server) ──
PORT=3000
APP_URL=http://localhost:3000

# ── قاعدة البيانات (PostgreSQL) ──
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/wasalny?schema=public"

# ── المصادقة (Auth) ──
JWT_SECRET=replace_with_a_long_random_string

# ── الخرائط (OpenRouteService) ──
ORS_API_KEY=your_openrouteservice_api_key_here
SEARCH_RADIUS_KM=5

# ── التسعير والمحفظة ──
# نسبة العمولة تُحدَّث فعلياً من قاعدة البيانات (جدول Config) عند التهيئة
COMMISSION_PERCENTAGE=15

# ── Firebase Admin SDK ──
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Cloudinary (رفع الصور) ──
# ⚠️ يجب تعيين هذه المتغيرات على Railway (Variables) وإلا فشل رفع الصور (502)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── بوابة الدفع كاشير (Kashier) — بيئة الإنتاج Live ──
# ⚠️ هذه الأسرار خاصة بالباك إند فقط — لا ترسلها أبداً إلى تطبيق Flutter
KASHIER_MID=YOUR_MID_HERE
KASHIER_MERCHANT_NAME="Waslny"
KASHIER_API_KEY=your_kashier_api_key_here
KASHIER_SECRET_KEY="your_kashier_secret_key_here"
KASHIER_MODE=live
